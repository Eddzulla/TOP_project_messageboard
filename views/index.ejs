<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title>Msg app</title>
</head>
<body>
    <%- include('../components/navbar', {links: links}); -%>

    
    <% for (let i = 0; i<messages.length; i++) { %>
        <div class="dynamic_msg">
        <a class="msg" href="msg/<%= i %>">
    <%- include('../components/messageBox', {message: messages[i]});  %>
    </a>
    </div>
    <% }; %>
    
    
    
</body>
</html>